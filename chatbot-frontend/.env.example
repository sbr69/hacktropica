# API Configuration (Required)
VITE_API_URL=http://localhost:8001

# Note: This frontend uses backend JWT authentication (email/password)
# No Firebase configuration needed for chatbot frontend

# Optional: Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Sentry Error Tracking
# VITE_SENTRY_DSN=https://your-sentry-dsn

# Note: All variables prefixed with VITE_ are exposed to the browser
# Vite only exposes variables that start with VITE_
